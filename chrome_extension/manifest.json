{
  "manifest_version": 2,
  "name": "HN Post Summarizer",
  "version": "1.0.0",
  "description": "Adds inline AI summaries to Hacker News posts.",
  "permissions": [
    "activeTab",
    "storage",
    "https://news.ycombinator.com/*",
    "http://localhost:3001/*",
    "https://localhost:3001/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "HN Post Summarizer"
  },
  "content_scripts": [
    {
      "matches": ["https://news.ycombinator.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
